root = true

# Todos los archivos
[*]
end_of_line = crlf
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

# C# — Tabs obligatorios
[*.cs]
indent_style = tab
indent_size = 4
tab_width = 4

# XML / csproj / config
[*.{xml,csproj,props,targets,config,resx}]
indent_style = tab
indent_size = 2
tab_width = 2

# JSON
[*.json]
indent_style = tab
indent_size = 2
tab_width = 2

# YAML / Docker
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false
