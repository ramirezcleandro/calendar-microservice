{
  "info": {
    "name": "NutriCenter - CalendarioEntregas",
    "_postman_id": "nutricenter-calendario-collection",
    "description": "Colección para probar api_security y el microservicio CalendarioEntregas.\n\nFlujo:\n1. [Security] Crear usuario\n2. [Security] Login → el token se guarda automáticamente en {{token}}\n3. Usar cualquier endpoint de Calendario (el token se envía automáticamente)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_security", "value": "http://localhost:8081", "type": "string" },
    { "key": "base_calendario", "value": "http://localhost:7020", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "calendarioId", "value": "", "type": "string" },
    { "key": "pacienteId", "value": "11111111-1111-1111-1111-111111111111", "type": "string" },
    { "key": "planAlimenticioId", "value": "22222222-2222-2222-2222-222222222222", "type": "string" }
  ],
  "item": [
    {
      "name": "🔐 Security (api_security :8081)",
      "item": [
        {
          "name": "1. Crear Usuario",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_security}}/api/users", "host": ["{{base_security}}"], "path": ["api", "users"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"testuser\",\n  \"patientId\": \"{{pacienteId}}\",\n  \"password\": \"Test1234\",\n  \"roleType\": 2\n}"
            }
          },
          "response": []
        },
        {
          "name": "2. Login → guarda token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.isSuccess && json.value) {",
                  "    pm.collectionVariables.set('token', json.value);",
                  "    console.log('Token guardado:', json.value.substring(0, 50) + '...');",
                  "} else {",
                  "    console.error('Login fallido:', JSON.stringify(json));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_security}}/api/authentications", "host": ["{{base_security}}"], "path": ["api", "authentications"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"Test1234\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Listar Usuarios",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_security}}/api/users?page=1&pageSize=10",
              "host": ["{{base_security}}"],
              "path": ["api", "users"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "10" }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "📅 Calendario (:7020)",
      "auth": {
        "type": "bearer",
        "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
      },
      "item": [
        {
          "name": "1. Crear Calendario",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.calendarioId) {",
                  "    pm.collectionVariables.set('calendarioId', json.calendarioId);",
                  "    console.log('CalendarioId guardado:', json.calendarioId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_calendario}}/api/calendario/crear", "host": ["{{base_calendario}}"], "path": ["api", "calendario", "crear"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pacienteId\": \"{{pacienteId}}\",\n  \"planAlimenticioId\": \"{{planAlimenticioId}}\",\n  \"fechaInicio\": \"2026-03-01\",\n  \"fechaFin\": \"2026-06-30\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "2. Agregar Dirección",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_calendario}}/api/calendario/{{calendarioId}}/agregar-direccion",
              "host": ["{{base_calendario}}"],
              "path": ["api", "calendario", "{{calendarioId}}", "agregar-direccion"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fecha\": \"2026-03-10\",\n  \"direccion\": \"Av. Corrientes 1234, CABA\",\n  \"referencias\": \"Piso 3, Depto B\",\n  \"latitud\": -34.6037,\n  \"longitud\": -58.3816\n}"
            }
          },
          "response": []
        },
        {
          "name": "3. Modificar Dirección",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_calendario}}/api/calendario/{{calendarioId}}/modificar-direccion",
              "host": ["{{base_calendario}}"],
              "path": ["api", "calendario", "{{calendarioId}}", "modificar-direccion"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fecha\": \"2026-03-10\",\n  \"nuevaDireccion\": \"Av. Santa Fe 5678, CABA\",\n  \"referencias\": \"Portería\",\n  \"latitud\": -34.5960,\n  \"longitud\": -58.3974\n}"
            }
          },
          "response": []
        },
        {
          "name": "4. Marcar No Entrega",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_calendario}}/api/calendario/{{calendarioId}}/marcar-no-entrega",
              "host": ["{{base_calendario}}"],
              "path": ["api", "calendario", "{{calendarioId}}", "marcar-no-entrega"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fecha\": \"2026-03-10\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "5. Reactivar Entrega",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_calendario}}/api/calendario/{{calendarioId}}/reactivar-entrega",
              "host": ["{{base_calendario}}"],
              "path": ["api", "calendario", "{{calendarioId}}", "reactivar-entrega"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fecha\": \"2026-03-10\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "6. Obtener Calendario por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_calendario}}/api/calendario/{{calendarioId}}",
              "host": ["{{base_calendario}}"],
              "path": ["api", "calendario", "{{calendarioId}}"]
            }
          },
          "response": []
        },
        {
          "name": "7. Listar Calendarios",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_calendario}}/api/calendario",
              "host": ["{{base_calendario}}"],
              "path": ["api", "calendario"]
            }
          },
          "response": []
        },
        {
          "name": "8. Listar por PacienteId",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_calendario}}/api/calendario?pacienteId={{pacienteId}}",
              "host": ["{{base_calendario}}"],
              "path": ["api", "calendario"],
              "query": [{ "key": "pacienteId", "value": "{{pacienteId}}" }]
            }
          },
          "response": []
        },
        {
          "name": "9. Próxima Entrega",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_calendario}}/api/calendario/{{calendarioId}}/proxima-entrega",
              "host": ["{{base_calendario}}"],
              "path": ["api", "calendario", "{{calendarioId}}", "proxima-entrega"]
            }
          },
          "response": []
        },
        {
          "name": "10. Direcciones Activas",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_calendario}}/api/calendario/{{calendarioId}}/direcciones-activas",
              "host": ["{{base_calendario}}"],
              "path": ["api", "calendario", "{{calendarioId}}", "direcciones-activas"]
            }
          },
          "response": []
        },
        {
          "name": "11. Desactivar Calendario",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_calendario}}/api/calendario/{{calendarioId}}/desactivar",
              "host": ["{{base_calendario}}"],
              "path": ["api", "calendario", "{{calendarioId}}", "desactivar"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
