          }
        },
        {
          "name": "Obtener direcciones activas",
          "request": {
            "method": "GET",
            "url": "{{direct_url}}/api/calendario/{{calendarioId}}/direcciones-activas"
          }
        },
        {
          "name": "Desactivar calendario",
          "request": {
            "method": "POST",
            "url": "{{direct_url}}/api/calendario/{{calendarioId}}/desactivar"
          }
        }
      ]
    }

  ]
}
