{
  "info": {
    "name": "NutriCenter - CalendarioEntregas",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "gateway_url",  "value": "http://localhost:8080" },
    { "key": "direct_url",   "value": "http://localhost:7020" },
    { "key": "token",        "value": "" },
    { "key": "calendarioId", "value": "" },
    { "key": "userId",       "value": "" }
  ],
  "item": [

    {
      "name": "Security",
      "item": [
        {
          "name": "Crear usuario",
          "request": {
            "method": "POST",
            "url": "{{gateway_url}}/api/users",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"admin\",\n  \"patientId\": \"00000000-0000-0000-0000-000000000001\",\n  \"password\": \"Admin123!\",\n  \"roleType\": 0\n}"
            }
          }
        },
        {
          "name": "Login (guarda token automaticamente)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.value) {",
                  "    pm.collectionVariables.set('token', json.value);",
                  "    console.log('Token guardado correctamente');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{gateway_url}}/api/authentications",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin123!\"\n}"
            }
          }
        },
        {
          "name": "Listar usuarios",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gateway_url}}/api/users?page=1&pageSize=10",
              "query": [
                { "key": "page",     "value": "1" },
                { "key": "pageSize", "value": "10" },
                { "key": "search",   "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Obtener usuario por ID",
          "request": {
            "method": "GET",
            "url": "{{gateway_url}}/api/users/{{userId}}"
          }
        },
        {
          "name": "Agregar rol a usuario",
          "request": {
            "method": "POST",
            "url": "{{gateway_url}}/api/users/{{userId}}/roles",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roleName\": \"admin\"\n}"
            }
          }
        },
        {
          "name": "Quitar rol a usuario",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{gateway_url}}/api/users/{{userId}}/roles?roleName=admin",
              "query": [{ "key": "roleName", "value": "admin" }]
            }
          }
        }
      ]
    },

    {
      "name": "Calendario (via Gateway :8080)",
      "auth": {
        "type": "bearer",
        "bearer": [{ "key": "token", "value": "{{token}}" }]
      },
      "item": [
        {
          "name": "Crear calendario",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.calendarioId) {",
                  "    pm.collectionVariables.set('calendarioId', json.calendarioId);",
                  "    console.log('CalendarioId guardado:', json.calendarioId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{gateway_url}}/api/calendario/crear",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pacienteId\": \"7c9e6679-7425-40de-944b-e07fc1f90ae7\",\n  \"planAlimenticioId\": \"3fa85f64-5717-4562-b3fc-2c963f66afa6\",\n  \"fechaInicio\": \"2026-03-10\",\n  \"fechaFin\": \"2026-04-10\"\n}"
            }
          }
        },
        {
          "name": "Listar calendarios",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gateway_url}}/api/calendario",
              "query": [
                { "key": "pacienteId", "value": "7c9e6679-7425-40de-944b-e07fc1f90ae7", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Obtener calendario por ID",
          "request": {
            "method": "GET",
            "url": "{{gateway_url}}/api/calendario/{{calendarioId}}"
          }
        },
        {
          "name": "Agregar direccion",
          "request": {
            "method": "POST",
            "url": "{{gateway_url}}/api/calendario/{{calendarioId}}/agregar-direccion",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fecha\": \"2026-03-15\",\n  \"direccion\": \"Av. Siempre Viva 742\",\n  \"referencias\": \"Edificio azul, piso 3\",\n  \"latitud\": -17.3935,\n  \"longitud\": -66.1570\n}"
            }
          }
        },
        {
          "name": "Modificar direccion",
          "request": {
            "method": "PUT",
            "url": "{{gateway_url}}/api/calendario/{{calendarioId}}/modificar-direccion",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fecha\": \"2026-03-15\",\n  \"nuevaDireccion\": \"Calle Potosi 123\",\n  \"referencias\": \"Cerca del parque central\",\n  \"latitud\": -17.3940,\n  \"longitud\": -66.1580\n}"
            }
          }
        },
        {
          "name": "Marcar dia no entrega",
          "request": {
            "method": "POST",
            "url": "{{gateway_url}}/api/calendario/{{calendarioId}}/marcar-no-entrega",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fecha\": \"2026-03-20\"\n}"
            }
          }
        },
        {
          "name": "Reactivar entrega",
          "request": {
            "method": "POST",
            "url": "{{gateway_url}}/api/calendario/{{calendarioId}}/reactivar-entrega",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fecha\": \"2026-03-20\"\n}"
            }
          }
        },
        {
          "name": "Obtener proxima entrega",
          "request": {
            "method": "GET",
            "url": "{{gateway_url}}/api/calendario/{{calendarioId}}/proxima-entrega"
          }
        },
        {
          "name": "Obtener direcciones activas",
          "request": {
            "method": "GET",
            "url": "{{gateway_url}}/api/calendario/{{calendarioId}}/direcciones-activas"
          }
        },
        {
          "name": "Desactivar calendario",
          "request": {
            "method": "POST",
            "url": "{{gateway_url}}/api/calendario/{{calendarioId}}/desactivar"
          }
        }
      ]
    },

